---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__col footer__brand">
      <div class="brand">
        <span class="brand__main">Bites</span>
        <span class="brand__sub">by Kanchan</span>
      </div>
      <p class="footer__tagline">From my kitchen to your table — curated Indian catering for 10 to 100 guests.</p>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Visit</h4>
      <ul class="footer__list">
        <li><a href="/">Home</a></li>
        <li><a href="/menu">Menu</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Contact</h4>
      <ul class="footer__list">
        <li><a href="tel:+13477284030">347-728-4030</a></li>
        <li><a href="mailto:hello@bitesbykanchan.com">bitesbykanchan@gmail.com</a></li>
        <li><a href="https://bitesbykanchan.com">bitesbykanchan.com</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Good to Know</h4>
      <ul class="footer__list footer__list--plain">
        <li>48 hour notice recommended</li>
        <li>Pickup available</li>
        <li>Delivery available upon request</li>
      </ul>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>© {year} Bites by Kanchan. All rights reserved.</span>
    <span>Made with care.</span>
  </div>
</footer>

<style>
  .footer {
    background: var(--burgundy-dk);
    color: rgba(250, 246, 238, 0.78);
    padding-block: 4rem 2rem;
    margin-top: 0;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.2fr 1.2fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(250, 246, 238, 0.12);
  }
  .footer .brand__main, .footer .brand__sub { color: var(--cream); display: block; }
  .footer .brand__main { font-family: var(--font-display); font-size: 1.75rem; line-height: 1; }
  .footer .brand__sub  { font-family: var(--font-display); font-style: italic; font-weight: 300; font-size: 0.95rem; color: var(--gold); margin-top: 0.25rem; }
  .footer__tagline {
    margin-top: 1.25rem;
    color: rgba(250, 246, 238, 0.7);
    max-width: 28ch;
    font-style: italic;
    font-family: var(--font-display);
    font-weight: 300;
  }
  .footer__heading {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .footer__list { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer__list a { color: rgba(250, 246, 238, 0.78); transition: color 0.2s; }
  .footer__list a:hover { color: var(--cream); }
  .footer__list--plain li { color: rgba(250, 246, 238, 0.7); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    font-size: 0.85rem;
    color: rgba(250, 246, 238, 0.55);
  }

  @media (max-width: 760px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .footer__inner { grid-template-columns: 1fr; }
  }
</style>
