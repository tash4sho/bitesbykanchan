---
import Ornament from './Ornament.astro';
---
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <span class="eyebrow rise rise-1">Curated Indian Catering · NYC</span>
      <h1 class="hero__title rise rise-2">
        From my <em>kitchen</em><br/>to your table.
      </h1>
      <p class="lede rise rise-3">
        Hand-crafted catering for 10 to 100 guests — biryani slow-cooked the way it should be,
        chaat assembled with care, paneer that tastes like a memory. Built for gatherings that matter.
      </p>
      <div class="hero__cta rise rise-4">
        <a href="/menu" class="btn btn--primary">Explore the menu →</a>
        <a href="/contact" class="btn btn--ghost">Book a tasting</a>
      </div>

      <div class="hero__meta rise rise-4">
        <div><strong>10–100</strong><span>guests</span></div>
        <div><strong>48 hr</strong><span>notice</span></div>
        <div><strong>Pickup</strong><span>or delivery</span></div>
      </div>
    </div>

    <aside class="hero__art" aria-hidden="true">
      <!-- Stylized illustrated thali — pure SVG, no external assets -->
      <svg viewBox="0 0 400 400" class="hero__svg">
        <defs>
          <radialGradient id="plate" cx="50%" cy="45%" r="55%">
            <stop offset="0%"  stop-color="#FFFCF4"/>
            <stop offset="100%" stop-color="#EFE6D2"/>
          </radialGradient>
          <pattern id="dots" width="6" height="6" patternUnits="userSpaceOnUse">
            <circle cx="3" cy="3" r="0.5" fill="#7A2B2B" opacity="0.25"/>
          </pattern>
        </defs>

        <!-- Decorative arc behind plate -->
        <circle cx="200" cy="200" r="190" fill="none" stroke="#C9A961" stroke-width="0.5" stroke-dasharray="2 4"/>
        <circle cx="200" cy="200" r="170" fill="none" stroke="#C9A961" stroke-width="0.5"/>

        <!-- Main plate -->
        <circle cx="200" cy="200" r="155" fill="url(#plate)" stroke="#C9A961" stroke-width="1.5"/>
        <circle cx="200" cy="200" r="145" fill="none" stroke="#C9A961" stroke-width="0.5" stroke-dasharray="1 3"/>

        <!-- Center bowl (curry) -->
        <circle cx="200" cy="200" r="55" fill="#7A2B2B"/>
        <circle cx="200" cy="200" r="55" fill="url(#dots)"/>
        <circle cx="200" cy="200" r="55" fill="none" stroke="#5C1F1F" stroke-width="2"/>
        <ellipse cx="195" cy="190" rx="8" ry="3" fill="#C9A961" opacity="0.6"/>

        <!-- Surrounding small bowls -->
        <g>
          <!-- Top bowl: rice -->
          <circle cx="200" cy="80" r="30" fill="#FFFCF4" stroke="#C9A961" stroke-width="1.5"/>
          <circle cx="195" cy="78" r="1" fill="#C9A961"/>
          <circle cx="205" cy="76" r="1" fill="#C9A961"/>
          <circle cx="200" cy="84" r="1" fill="#C9A961"/>
          <circle cx="190" cy="82" r="1" fill="#C9A961"/>
          <circle cx="210" cy="84" r="1" fill="#C9A961"/>

          <!-- Right bowl: dal -->
          <circle cx="320" cy="200" r="30" fill="#C9A961" stroke="#A88842" stroke-width="1.5"/>
          <circle cx="320" cy="200" r="20" fill="#A88842" opacity="0.5"/>

          <!-- Bottom bowl: chutney green -->
          <circle cx="200" cy="320" r="30" fill="#6B7F4F" stroke="#5A6B43" stroke-width="1.5"/>

          <!-- Left bowl: dal makhni -->
          <circle cx="80" cy="200" r="30" fill="#5C1F1F" stroke="#3D1414" stroke-width="1.5"/>
          <ellipse cx="78" cy="195" rx="6" ry="2" fill="#C9A961" opacity="0.5"/>
        </g>

        <!-- Diagonal smaller bowls -->
        <circle cx="115" cy="115" r="20" fill="#FAF6EE" stroke="#C9A961" stroke-width="1"/>
        <circle cx="115" cy="115" r="8" fill="#7A2B2B"/>
        <circle cx="285" cy="115" r="20" fill="#FAF6EE" stroke="#C9A961" stroke-width="1"/>
        <circle cx="285" cy="115" r="8" fill="#6B7F4F"/>
        <circle cx="115" cy="285" r="20" fill="#FAF6EE" stroke="#C9A961" stroke-width="1"/>
        <circle cx="115" cy="285" r="8" fill="#C9A961"/>
        <circle cx="285" cy="285" r="20" fill="#FAF6EE" stroke="#C9A961" stroke-width="1"/>
        <circle cx="285" cy="285" r="8" fill="#7A2B2B"/>

        <!-- Decorative herbs -->
        <g transform="translate(40 40) rotate(-30)" stroke="#6B7F4F" stroke-width="1" fill="none">
          <path d="M0 0 Q 5 15, 0 30"/>
          <path d="M0 5 Q -8 8, -10 15"/>
          <path d="M0 12 Q 8 15, 10 22"/>
          <path d="M0 20 Q -6 22, -8 28"/>
        </g>
        <g transform="translate(360 360) rotate(150)" stroke="#6B7F4F" stroke-width="1" fill="none">
          <path d="M0 0 Q 5 15, 0 30"/>
          <path d="M0 5 Q -8 8, -10 15"/>
          <path d="M0 12 Q 8 15, 10 22"/>
          <path d="M0 20 Q -6 22, -8 28"/>
        </g>

        <!-- Chili accent -->
        <g transform="translate(355 50) rotate(40)">
          <path d="M0 0 C -2 0, -3 2, -2 3 C -8 5, -12 12, -10 18 C -5 19, 2 16, 4 10 C 5 6, 3 1, 0 0 Z"
                fill="#7A2B2B" stroke="#5C1F1F" stroke-width="0.5"/>
          <path d="M-1 -1 Q 1 -4, 4 -3" stroke="#6B7F4F" stroke-width="1" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 7vw, 6rem) clamp(3rem, 8vw, 7rem);
    position: relative;
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .hero__title {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-weight: 300;
    letter-spacing: -0.02em;
  }
  .hero__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--burgundy);
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .hero__meta {
    display: flex;
    gap: 2.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px dotted var(--line-strong);
  }
  .hero__meta div {
    display: flex;
    flex-direction: column;
  }
  .hero__meta strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--burgundy);
    line-height: 1;
  }
  .hero__meta span {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 0.4rem;
  }

  .hero__art {
    position: relative;
    aspect-ratio: 1;
    max-width: 520px;
    margin-inline: auto;
    width: 100%;
  }
  .hero__svg {
    width: 100%;
    height: 100%;
    animation: heroPlate 1.4s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.3s;
  }
  @keyframes heroPlate {
    from { opacity: 0; transform: scale(0.92) rotate(-3deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @media (max-width: 860px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__art { order: -1; max-width: 360px; }
    .hero__meta { gap: 1.5rem; }
  }
</style>
