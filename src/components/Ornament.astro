---
export interface Props {
  type?: 'chili' | 'leaf' | 'spice' | 'divider';
  size?: number;
  color?: string;
}
const { type = 'leaf', size = 24, color = 'currentColor' } = Astro.props;
---
{type === 'leaf' && (
  <svg width={size} height={size} viewBox="0 0 24 24" aria-hidden="true">
    <path d="M12 2 C 7 6, 5 12, 6 20 C 12 18, 18 14, 19 5 C 16 4, 14 3, 12 2 Z"
          fill="none" stroke={color} stroke-width="1.2" stroke-linejoin="round"/>
    <path d="M12 4 Q 11 12, 8 18" fill="none" stroke={color} stroke-width="1" stroke-linecap="round"/>
  </svg>
)}

{type === 'chili' && (
  <svg width={size} height={size} viewBox="0 0 24 24" aria-hidden="true">
    <path d="M16 4 C 14 4, 13 5, 13 6 C 13 7, 14 7, 14 8 C 8 10, 4 16, 6 21 C 11 22, 18 18, 20 12 C 21 9, 19 5, 16 4 Z"
          fill="none" stroke={color} stroke-width="1.2" stroke-linejoin="round"/>
    <path d="M14 5 Q 16 3, 18 4" fill="none" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{type === 'spice' && (
  <svg width={size} height={size} viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="6" cy="12" r="1.5" fill={color}/>
    <circle cx="12" cy="9" r="2" fill={color}/>
    <circle cx="18" cy="12" r="1.5" fill={color}/>
    <circle cx="9" cy="16" r="1" fill={color}/>
    <circle cx="15" cy="16" r="1" fill={color}/>
  </svg>
)}

{type === 'divider' && (
  <svg width={size * 2.5} height={size / 2} viewBox="0 0 60 12" aria-hidden="true">
    <circle cx="30" cy="6" r="2.5" fill="none" stroke={color} stroke-width="1"/>
    <circle cx="30" cy="6" r="0.8" fill={color}/>
    <line x1="2"  y1="6" x2="22" y2="6" stroke={color} stroke-width="0.8" stroke-linecap="round"/>
    <line x1="38" y1="6" x2="58" y2="6" stroke={color} stroke-width="0.8" stroke-linecap="round"/>
  </svg>
)}
